{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/chat.js", "use": "@vercel/node" },
    { "src": "api/cartelera.js", "use": "@vercel/node" },
    { "src": "api/mundial.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/chat", "dest": "/api/chat.js" },
    { "src": "/api/cartelera", "dest": "/api/cartelera.js" },
    { "src": "/api/mundial", "dest": "/api/mundial.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
